apiVersion: v1
data:
  gnb-config.yml: |
    # Auto-generated by srsran-operator – DO NOT EDIT
    # DU: F1CCUCPAddr=172.5.0.1 F1C=172.5.0.0 F1U=172.6.0.0

    f1ap:
      cu_cp_addr: 172.5.0.1
      bind_addr: 172.5.0.0

    f1u:
      socket:
      - bind_addr: 172.6.0.0

    ru_sdr:
      device_driver: zmq
      device_args: tx_port=tcp://172.6.0.0:2000,rx_port=tcp://172.6.0.1:2001,base_srate=23.04e6
      srate: 23.04
      tx_gain: 75
      rx_gain: 75

    cell_cfg:
      dl_arfcn: 368500
      band: 3
      channel_bandwidth_MHz: 20
      common_scs: 15
      plmn: "20893"
      tac: 1
      pci: 1
      pdcch:
        common:
          ss0_index: 0
          coreset0_index: 12
        dedicated:
          ss2_type: common
          dci_format_0_1_and_1_1: false
      prach:
        prach_config_index: 1
      pdsch:
        mcs_table: qam64
      pusch:
        mcs_table: qam64
      slicing:
        - sst: 1
          sd: 66051
          sched_cfg:
            min_prb_policy_ratio: 0
            max_prb_policy_ratio: 50
            priority: 10
        - sst: 1
          sd: 1122867
          sched_cfg:
            min_prb_policy_ratio: 0
            max_prb_policy_ratio: 100
            priority: 200

    log:
      filename: /tmp/logs/du.log
      all_level: info

    pcap:
      mac_enable: false
      f1ap_enable: false
      f1u_enable: false

    expert_execution:
      threads:
        main_pool:
          backoff_period: 1000
